        </mxCell>
        <mxCell id="trigger-user" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#dae5f2;strokeColor=#4a6fa5;fontSize=12;fontStyle=1;" value="① ユーザー応答 (HIL)&#xa;AI 提案 4 つから選ぶ&#xa;or 自由記載 / 委譲ボタン" vertex="1">
          <mxGeometry height="80" width="240" x="440" y="180" as="geometry" />
