        <mxCell id="legend-mvp-note" parent="1" style="text;html=1;align=left;fontSize=11;fontStyle=2;fontColor=#888;" value="MVP 設計:&#xa;・Profile Agent 除外 (TODO_construction.md)&#xa;・Suggestion + Delegation&amp;Execution を 1 Agent に統合&#xa;・Phase 概念を user 面から撤廃&#xa;・Active モードは常に「4 提案 + 自由記載」&#xa;・Autonomous モードは完全委譲 or 3 回トレーニングで遷移&#xa;・SELF_DECISION_LIMIT = 3 (auto-graduate)&#xa;・HIL: AI 提案 → user 選択、 wizard 入力なし" vertex="1">
          <mxGeometry height="128" width="310" x="56" y="240" as="geometry" />
        </mxCell>
        <mxCell id="active-mode-label" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#1f4ea8;" value="Active モード (user が AI と対話)" vertex="1">
