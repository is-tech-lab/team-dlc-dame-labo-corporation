        <mxCell id="output-voice" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#f8b6c0;strokeColor=#c53030;fontSize=11;fontStyle=1;align=center;" value="音声報告&#xa;「やっといたよ：お母さんに返信しといた」&#xa;「カートの本買っといた」「サブスク 2 つ解約しといた」" vertex="1">
          <mxGeometry height="70" width="460" x="1120" y="270" as="geometry" />
        </mxCell>
        <mxCell id="agent-row-label" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#666;" value="Agent (MVP: 1 つに統合)" vertex="1">
          <mxGeometry height="30" width="200" x="40" y="420" as="geometry" />
        </mxCell>
        <mxCell id="agent-suggest" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#e3d5f0;strokeColor=#5a3a8a;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;" value="ダメ・ラボ Agent (単一)&#xa;&#xa;責務 (mode に応じて切替):&#xa;&#xa;【Active モード】&#xa;• 観察データから context 推論 (内部処理)&#xa;• 常に 4 提案 + 自由記載欄 を返す (Bedrock 呼出)&#xa;• 単発委譲時は 4 つから 1 つ選んで返す&#xa;• 選択ログ作成 (DynamoDB 書込)&#xa;&#xa;【Autonomous モード】&#xa;• 委譲アクション処理 (DynamoDB 書込)&#xa;• 受信代行 (来た連絡 / カート / 通知への応答)&#xa;• 自発代行 (誕生日リマインド / サブスク見直し / 日用品補充 等の AI 発)&#xa;• Bedrock 自律判断 + Polly 音声報告生成&#xa;&#xa;MVP: context 推論は hardcoded、本番: 実 LINE/Slack/EC 連携" vertex="1">
          <mxGeometry height="320" width="540" x="600" y="450" as="geometry" />
        </mxCell>
        <mxCell id="agent-merged-note" parent="1" style="text;html=1;align=center;fontSize=10;fontStyle=2;fontColor=#888;" value="⚠ 当初は 2 Agent 構成 (サジェスチョン + 委譲＆実行) だったが&#xa;Discovery Mock のチームレビュー後 (2026-05-02) に MVP として 1 つに統合。&#xa;将来 (Construction 以降) で再分離する余地あり (TODO_construction.md 参照)" vertex="1">
          <mxGeometry height="50" width="540" x="600" y="780" as="geometry" />
        </mxCell>
