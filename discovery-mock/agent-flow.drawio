        <mxCell id="trigger-sched" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#f2d8de;strokeColor=#c53030;fontSize=11;fontStyle=1;" value="③ EventBridge スケジュール&#xa;(自発代行: 誕生日リマインド / サブスク見直し /&#xa;日用品補充 等)" vertex="1">
          <mxGeometry height="80" width="220" x="1120" y="160" as="geometry" />
        </mxCell>
        <mxCell id="trigger-inbox" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#f2d8de;strokeColor=#c53030;fontSize=11;fontStyle=1;" value="③ 受信トリガー&#xa;(LINE/Slack/メール 着信、&#xa;Amazon カート / セール通知 等、受信代行)" vertex="1">
          <mxGeometry height="80" width="220" x="1360" y="160" as="geometry" />
